# Banco de dados (Neon PostgreSQL)
# Formato: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@host/phisioflow?sslmode=require"

# Segredo para assinar cookies de sessão (mínimo 32 chars)
SESSION_SECRET="substitua-por-uma-string-aleatoria-longa"

# Chave simétrica usada para criptografar credenciais de integrações (e.g. Gmail App Password)
# Gere com: openssl rand -base64 32
INTEGRATION_ENCRYPTION_KEY="substitua-por-32-bytes-em-base64"
